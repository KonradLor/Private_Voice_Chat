# Nukopijuok i .env ir uzpildyk savo reiksmemis:
#   cp .env.example .env
# .env NIEKADA neikelk i git (zr. .gitignore).

# TURN/STUN serverio domenas (turi rodyti i sio serverio viesa IP).
# Pvz. galima naudoti ta pati domena kaip ir appsui arba poddomena.
TURN_HOST=turn.tavo-domenas.lt

# coturn realm (paprastai = TURN_HOST).
TURN_REALM=turn.tavo-domenas.lt

# Bendras slaptas raktas. Naudoja IR app'as (kredencialu generavimui),
# IR coturn (ju tikrinimui). Sugeneruok stipru, pvz.:
#   openssl rand -hex 32
TURN_SECRET=pakeisk_mane_ilgu_atsitiktiniu_raktu

# Laikinu TURN kredencialu galiojimas sekundemis (numatytas 3600 = 1 val).
TURN_TTL=3600

# Sio serverio VIESAS IP adresas (Oracle instance public IP).
# Butinas, kad coturn teisingai pranestu relay adresa.
PUBLIC_IP=123.45.67.89

# ============================================================
# OIDC prisijungimas (Authentik) - BUTINA, kitaip login neveiks
# ============================================================
# Reiksmes imami is Authentik OAuth2/OpenID Provider.
OIDC_CLIENT_ID=pakeisk_client_id
OIDC_CLIENT_SECRET=pakeisk_client_secret

# Authentik endpoint'ai (pakeisk auth.tavo-domenas.lt i savo Authentik adresa).
# Tikslius URL rasi Authentik provider'io puslapyje arba .well-known/openid-configuration.
OIDC_AUTHORIZE_URL=https://auth.tavo-domenas.lt/application/o/authorize/
OIDC_TOKEN_URL=https://auth.tavo-domenas.lt/application/o/token/
OIDC_USERINFO_URL=https://auth.tavo-domenas.lt/application/o/userinfo/

# Kur Authentik grazina po prisijungimo. TURI sutapti su Authentik provider'io
# Redirect URI ir su tavo voice domenu.
OIDC_REDIRECT_URI=https://voice.tavo-domenas.lt/auth/callback

# Authentik grupe, kurios nariai laikomi adminais (gali ismesti dalyvius).
OIDC_ADMIN_GROUP=authentik Admins

# ============================================================
# Vidinis service-to-service tokenas (NEBUTINA)
# ============================================================
# Naudojamas tik jei centrine admin panele kvies /internal/set-active
# (vartotojo deaktyvavimo propagavimui). Sugeneruok: openssl rand -hex 32
# Jei nenaudoji - palik tuscia, /internal/* bus isjungti.
INTERNAL_API_TOKEN=
